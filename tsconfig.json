{
    "include": [
        "node_modules/qr-code-generator/typescript-javascript/qrcodegen.ts",
        "app/**/*"
    ],
    "exclude": [
        "node_modules/qr-code-generator/typescript-javascript/qrcodegen-output-demo.ts",
        "node_modules/qr-code-generator/typescript-javascript/qrcodegen-input-demo.ts"
    ],
    "compilerOptions": {
        "strict": false,
        "forceConsistentCasingInFileNames": true,
        "sourceMap": true,
        "target": "es2017",
        "lib": ["ES2022", "dom", "ES2022.Intl"],
        "moduleResolution": "bundler",
        "module": "esnext"
    }
